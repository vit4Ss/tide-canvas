# Copy this file to .env on the server, then fill the values.

# Public site
SITE_ADDRESS=tide.tcmzhan.com
SITE_URL=https://tide.tcmzhan.com

# Required secrets. Generate with: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=
JWT_SECRET=

# Upload limits
MAX_FILE_SIZE=100MB
MAX_REQUEST_SIZE=100MB

# Mail. Leave MAIL_HOST empty to disable real SMTP sending.
MAIL_ENABLED=true
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=TideCanvas
MAIL_REPLY_TO=
MAIL_SMTP_AUTH=true
MAIL_STARTTLS=true
MAIL_SSL=false
MAIL_SOCKS_HOST=
MAIL_SOCKS_PORT=7897

# Local storage by default. Switch STORAGE_KIND=oss when Aliyun OSS is ready.
STORAGE_KIND=local
STORAGE_MAX_SIZE=52428800
STORAGE_ALLOWED_TYPES=image/jpeg,image/png,image/gif,image/webp,video/mp4,video/webm
OSS_ENDPOINT=
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_BUCKET=
OSS_PREFIX=uploads/
OSS_CDN_DOMAIN=

# OAuth login. Frontend public client IDs are baked during docker build.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
WECHAT_APP_ID=
WECHAT_APP_SECRET=
