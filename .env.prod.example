# ============================================================
# TideCanvas 生产环境变量模板
# 用法: cp .env.prod.example .env && 按注释填写
# ============================================================

# ---- 站点地址(必填) ----
# 有域名: SITE_ADDRESS=canvas.example.com  SITE_URL=https://canvas.example.com
# 无域名临时按 IP: SITE_ADDRESS=:80        SITE_URL=http://<服务器IP>
SITE_ADDRESS=tide.tcmzhan.com
SITE_URL=https://tide.tcmzhan.com

# ---- 安全(必填,务必使用强随机值) ----
# 生成示例: openssl rand -base64 32
MYSQL_ROOT_PASSWORD=
JWT_SECRET=

# ---- 邮件(可选覆盖;不填则用 application.yml 内置的 Gmail 配置) ----
# 服务器能直连 Gmail(海外机房): MAIL_SOCKS_HOST 留空即可
# 大陆机房连不上 Gmail: 配置服务器上的代理(MAIL_SOCKS_HOST/PORT),或改用国内 SMTP(改 MAIL_HOST/PORT/USERNAME/PASSWORD,465 端口需同时设 MAIL_SSL=true MAIL_STARTTLS=false)
MAIL_SOCKS_HOST=
#MAIL_SOCKS_PORT=7897
#MAIL_HOST=smtp.gmail.com
#MAIL_PORT=587
#MAIL_USERNAME=ad@tcmzhan.com
#MAIL_PASSWORD=
#MAIL_FROM_NAME=TideCanvas

# ---- OAuth 登录(可选;client-id 前端构建期内联,改后需 --build 重新构建 frontend) ----
#GITHUB_CLIENT_ID=
#GITHUB_CLIENT_SECRET=
#GOOGLE_CLIENT_ID=
#GOOGLE_CLIENT_SECRET=
#WECHAT_APP_ID=
#WECHAT_APP_SECRET=
