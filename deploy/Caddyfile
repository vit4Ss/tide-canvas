# SITE_ADDRESS 为域名(如 canvas.example.com)时 Caddy 自动申请并续期 Let's Encrypt 证书;
# 为 ":80" 时仅 HTTP(无域名按 IP 访问的临时形态)。
{$SITE_ADDRESS} {
	encode gzip

	# WebSocket 直连后端：Next/Vercel 的 rewrites 不转发 WS 升级，故 /api/im/ws 由 Caddy 直接代理到后端。
	@imws path /api/im/ws
	reverse_proxy @imws backend:8080

	# 其余请求透传给 Next(其 /api/* rewrites 再代理到后端 REST)
	reverse_proxy frontend:3000 {
		flush_interval -1
	}
}
