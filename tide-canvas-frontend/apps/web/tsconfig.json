{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    // 沿用旧项目的严格度：旧代码在 strict 下已通过，但未开 noUncheckedIndexedAccess；
    // monorepo base 默认开了它会误报上百处索引访问，这里关掉以对齐旧项目。
    "noUncheckedIndexedAccess": false,
    "paths": {
      "@/*": ["./*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.mts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
