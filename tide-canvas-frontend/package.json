{
  "name": "tide-canvas-frontend",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "build": "npm --workspace web run build",
    "dev": "turbo dev",
    "lint": "npm --workspaces --if-present run lint",
    "format": "npm --workspaces --if-present run format",
    "typecheck": "npm --workspaces --if-present run typecheck"
  },
  "devDependencies": {
    "@workspace/eslint-config": "*",
    "@workspace/typescript-config": "*",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "turbo": "^2.9.15",
    "typescript": "^5"
  },
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ]
}
