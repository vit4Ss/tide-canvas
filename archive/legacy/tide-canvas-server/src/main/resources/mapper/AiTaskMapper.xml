<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tidecanvas.mapper.AiTaskMapper">

    <resultMap id="BaseResultMap" type="com.tidecanvas.model.entity.AiTaskDO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="project_id" property="projectId"/>
        <result column="handler_name" property="handlerName"/>
        <result column="model_id" property="modelId"/>
        <result column="input_params" property="inputParams"/>
        <result column="result_url" property="resultUrl"/>
        <result column="result_meta" property="resultMeta"/>
        <result column="status" property="status"/>
        <result column="progress" property="progress"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="cost" property="cost"/>
        <result column="complete_time" property="completeTime"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 关联查询模型名称 -->
    <resultMap id="WithModelResultMap" type="com.tidecanvas.model.entity.AiTaskDO" extends="BaseResultMap">
        <result column="model_name" property="modelName"/>
    </resultMap>

    <!-- 查询任务并关联模型名称 -->
    <select id="selectWithModel" resultMap="WithModelResultMap">
        SELECT t.*, m.name AS model_name
        FROM ai_task t
        LEFT JOIN ai_model m ON t.model_id = m.id
        WHERE t.deleted = 0 AND t.id = #{taskId}
    </select>

    <!-- 今日API调用次数 -->
    <select id="countTodayCalls" resultType="java.lang.Long">
        SELECT COUNT(*) FROM ai_task
        WHERE deleted = 0 AND DATE(create_time) = CURDATE()
    </select>

    <!-- 按Handler统计调用量 -->
    <select id="countByHandler" resultType="java.util.Map">
        SELECT handler_name AS handlerName, COUNT(*) AS count
        FROM ai_task
        WHERE deleted = 0
        GROUP BY handler_name
        ORDER BY count DESC
    </select>

    <!-- 按日期统计API调用量 -->
    <select id="countByDateRange" resultType="java.util.Map">
        SELECT DATE(create_time) AS date, COUNT(*) AS count
        FROM ai_task
        WHERE deleted = 0
          AND create_time BETWEEN #{startDate} AND #{endDate}
        GROUP BY DATE(create_time)
        ORDER BY date
    </select>

    <!-- 模型使用排行(已删除/失联的模型不参与排行) -->
    <select id="modelUsageRank" resultType="java.util.Map">
        SELECT m.name AS modelName, COUNT(t.id) AS callCount
        FROM ai_task t
        INNER JOIN ai_model m ON t.model_id = m.id
        WHERE t.deleted = 0
        GROUP BY m.name
        ORDER BY callCount DESC
        LIMIT #{limit}
    </select>

</mapper>
