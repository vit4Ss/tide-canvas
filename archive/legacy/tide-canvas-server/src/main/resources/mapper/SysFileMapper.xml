<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.tidecanvas.mapper.SysFileMapper">

    <resultMap id="BaseResultMap" type="com.tidecanvas.model.entity.SysFileDO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="original_name" property="originalName"/>
        <result column="stored_name" property="storedName"/>
        <result column="file_path" property="filePath"/>
        <result column="file_url" property="fileUrl"/>
        <result column="file_size" property="fileSize"/>
        <result column="file_type" property="fileType"/>
        <result column="mime_type" property="mimeType"/>
        <result column="hash" property="hash"/>
        <result column="storage_type" property="storageType"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="deleted" property="deleted"/>
    </resultMap>

    <!-- 统计用户已用存储空间 -->
    <select id="sumStorageByUserId" resultType="java.lang.Long">
        SELECT COALESCE(SUM(file_size), 0) FROM sys_file
        WHERE deleted = 0 AND user_id = #{userId}
    </select>

    <!-- 统计平台总存储 -->
    <select id="sumTotalStorage" resultType="java.lang.Long">
        SELECT COALESCE(SUM(file_size), 0) FROM sys_file
        WHERE deleted = 0
    </select>

    <!-- 按文件类型统计 -->
    <select id="countByFileType" resultType="java.util.Map">
        SELECT file_type AS fileType, COUNT(*) AS count, SUM(file_size) AS totalSize
        FROM sys_file
        WHERE deleted = 0
        GROUP BY file_type
    </select>

</mapper>
